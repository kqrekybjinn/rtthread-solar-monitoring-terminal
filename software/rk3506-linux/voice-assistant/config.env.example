# Voice assistant runtime configuration.

VOICE_DIR=/userdata/voice-assistant
CAPTURE_DEV=/dev/snd/pcmC0D0c
PLAYBACK_DEV=/dev/snd/pcmC1D0p
RECORD_SECONDS=5
RECORD_GAIN=16
PLAY_GAIN=2

# Optional cloud adapters. Each program should be executable on the board.
# ASR_PROGRAM input.wav                 -> stdout recognized text
# CHAT_PROGRAM user_text.txt            -> stdout reply text
# TTS_PROGRAM reply_text.txt output.wav -> writes PCM S16_LE WAV
ASR_PROGRAM=/userdata/voice-assistant/tencent_asr.sh
CHAT_PROGRAM=/userdata/voice-assistant/agent_chat.sh
TTS_PROGRAM=/userdata/voice-assistant/prompt_tts.sh

# Fixed prompt audio library. Runtime plays pre-generated WAV files instead of realtime TTS.
PROMPT_AUDIO_DIR=/userdata/voice-assistant/prompts
PROMPT_FALLBACK_CODE=done

# Fast local eSpeak Chinese TTS. Tuned to be calmer than the default voice.
LOCAL_TTS_VOICE=cmn
LOCAL_TTS_SPEED=125
LOCAL_TTS_AMPLITUDE=90
LOCAL_TTS_PITCH=28
LOCAL_TTS_WORD_GAP=8

# Optional local neural Chinese TTS. Better than eSpeak but too slow on RK3506 for normal dialogue.
SHERPA_TTS_RUNTIME=/userdata/voice-assistant/sherpa-onnx
SHERPA_TTS_MODEL_DIR=/userdata/voice-assistant/sherpa-tts-model/vits-piper-zh_CN-huayan-x_low
SHERPA_TTS_MODEL_FILE=/userdata/voice-assistant/sherpa-tts-model/vits-piper-zh_CN-huayan-x_low/zh_CN-huayan-x_low.onnx
SHERPA_TTS_LEXICON_FILE=/userdata/voice-assistant/sherpa-tts-model/vits-piper-zh_CN-huayan-x_low/lexicon.txt
SHERPA_TTS_TOKENS_FILE=/userdata/voice-assistant/sherpa-tts-model/vits-piper-zh_CN-huayan-x_low/tokens.txt
SHERPA_TTS_THREADS=2
SHERPA_TTS_SID=0
SHERPA_TTS_LENGTH_SCALE=1.0

# Wake-word loop.
WAKE_PHRASE=小电小电小电
WAKE_SECONDS=3
TURN_SECONDS=5
WAKE_COOLDOWN=2
WAKE_ACK_TEXT=我在。

# Local KWS wake word. This does not call cloud ASR.
WAKE_ENGINE=kws
KWS_ROOT=/userdata/voice-assistant/kws
KWS_MODEL_DIR=/userdata/voice-assistant/kws/model/sherpa-onnx-kws-zipformer-wenetspeech-3.3M-2024-01-01
KWS_BIN=/userdata/voice-assistant/kws/bin/sherpa-onnx-keyword-spotter
KWS_KEYWORDS=/userdata/voice-assistant/kws/keywords.txt
KWS_TOKENS=/userdata/voice-assistant/kws/model/sherpa-onnx-kws-zipformer-wenetspeech-3.3M-2024-01-01/tokens.txt
KWS_ENCODER=/userdata/voice-assistant/kws/model/sherpa-onnx-kws-zipformer-wenetspeech-3.3M-2024-01-01/encoder-epoch-12-avg-2-chunk-16-left-64.int8.onnx
KWS_DECODER=/userdata/voice-assistant/kws/model/sherpa-onnx-kws-zipformer-wenetspeech-3.3M-2024-01-01/decoder-epoch-12-avg-2-chunk-16-left-64.onnx
KWS_JOINER=/userdata/voice-assistant/kws/model/sherpa-onnx-kws-zipformer-wenetspeech-3.3M-2024-01-01/joiner-epoch-12-avg-2-chunk-16-left-64.int8.onnx
KWS_THREADS=2
KWS_SCORE=3.0
KWS_THRESHOLD=0.35
KWS_COOLDOWN=2
KWS_RECORD_SECONDS=2
AWAKE_WAV=/userdata/voice-assistant/prompts/awake.wav

# Optional MQTT publishing adapter:
# MQTT_PUBLISH_PROGRAM topic payload_file
MQTT_PUBLISH_PROGRAM=
MQTT_TOPIC_PREFIX=device/voice
